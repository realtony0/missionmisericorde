generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Achievement {
  id               String   @id @default(cuid())
  number           Int      @unique
  name             String
  category         String   // Puits | Mini_forage | Internats | Mosquees | Autres
  village          String?
  commune          String?
  arrondissement   String?
  department       String?
  region           String?
  location         String?
  lat              Float?
  lng              Float?
  note             String?
  description      String?
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  photos           String   // JSON array of Cloudinary URLs
  videoUrl         String?
  sourceProjectId  String?  @unique
}

model OngoingProject {
  id                   String   @id @default(cuid())
  number               Int?     @unique
  title                String
  category             String   @default("Puits")
  location             String?
  region               String?
  lat                  Float?
  lng                  Float?
  startDate            DateTime?
  description          String?
  targetAmount         Float?
  currentAmount        Float    @default(0)
  progress             Int      // 0-100
  status               String   @default("En cours") // "En cours" | "Terminé"
  inaugurationVideoUrl String?
  archiveToAchievements Boolean @default(true)
  archivedAt           DateTime?
  archivedAchievementId String? @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  steps                ProjectStep[]
  campaigns            DonationCampaign[]

  @@index([status, updatedAt])
}

model ProjectStep {
  id          String   @id @default(cuid())
  projectId   String
  project     OngoingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String?
  date        DateTime @default(now())
  description String
  photos      String   // JSON array
  videoUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, order])
}

model DonationCampaign {
  id            String   @id @default(cuid())
  title         String
  description   String?
  targetAmount  Float
  currentAmount Float    @default(0)
  type          String   @default("cagnotte") // "cagnotte" | "libre"
  projectId     String?  // lien optionnel vers OngoingProject
  project       OngoingProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
